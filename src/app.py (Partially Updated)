from flask import Flask, request, jsonify, render_template, redirect, url_for
from dynamodb_operations import get_item_from_dynamodb

app = Flask(__name__)

todos = {}

# Example integration with DynamoDB. You may want different keys based on your schema.
@app.route("/api/dynamodb_todo/<string:todo_id>")
def get_todo_from_dynamodb(todo_id):
    # Example of using DynamoDB (Table name and key structure should match your setup)
    table_name = 'TodosTable'
    key = {'id': todo_id}

    item = get_item_from_dynamodb(table_name, key)
    if item:
        return jsonify(item)
    else:
        return jsonify({"error": "Item not found"}), 404

